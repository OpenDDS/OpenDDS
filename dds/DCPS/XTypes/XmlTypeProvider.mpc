project(OpenDDS_XTypes_Xml): dcpslib, optional_xerces, install, dds_versioning_idl_defaults {
  sharedname = OpenDDS_XTypes_Xml
  dynamicflags = OPENDDS_XTYPES_XML_BUILD_DLL
  requires += no_opendds_safety_profile
  requires += xerces3
  includes += ../..

  IDL_Files {
  }

  Source_Files {
    XmlTypeProvider.cpp
  }

  Header_Files {
    XmlTypeProvider.h
    XmlTypeProvider_export.h
  }

  specific {
    install_dir = dds/DCPS/XTypes
  }
}
